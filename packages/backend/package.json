{
  "name": "@synaps/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "tsx src/worker.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@synaps/shared": "*",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.5.5",
    "bullmq": "^5.30.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.0",
    "jstat": "^1.9.6",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "simple-statistics": "^7.8.9",
    "tesseract.js": "^5.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
